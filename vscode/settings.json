{
  // Open settings.json when editing settings
  "workbench.settings.editor": "json",

  // Icon Theme
  "workbench.iconTheme": "symbols",

  // Typeface
  "editor.fontFamily": "'SF Mono', monospace",
  "editor.fontWeight": "normal",
  "editor.fontSize": 14,
  "terminal.integrated.fontSize": 12,

  // Editor
  "editor.lineNumbers": "relative",
  "editor.tabSize": 2,
  "editor.detectIndentation": false,
  "editor.guides.indentation": false,
  "editor.linkedEditing": true,
  "editor.stickyScroll.enabled": false,
  "editor.renderLineHighlight": "none",
  "editor.occurrencesHighlight": "off",
  "editor.lineDecorationsWidth": 40, // Left padding before code
  "editor.cursorSmoothCaretAnimation": "on",

  // Layout
  "workbench.sideBar.location": "right",
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "workbench.tree.indent": 16,
  "workbench.navigationControl.enabled": false,
  "chat.commandCenter.enabled": false,
  "breadcrumbs.enabled": false,
  "workbench.tree.enableStickyScroll": false,
  "explorer.compactFolders": false,
  "workbench.editor.showTabs": "single",
  "workbench.activityBar.location": "default",
  "git.decorations.enabled": false,
  "window.commandCenter": false,
  "window.titleBarStyle": "custom",
  "window.title": "${dirty}${activeEditorShort}${separator}${rootName}",

  // Hide scrollbars and rulers
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "hidden",
  "editor.overviewRulerBorder": false,
  // "editor.hideCursorInOverviewRuler": true,

  // Minimap
  "editor.minimap.renderCharacters": true,
  "editor.minimap.enabled": false,

  // Custom styling
  "custom-ui-style.font.sansSerif": "Bricolage Grotesque",
  //"custom-ui-style.font.monospace": "CaskaydiaMono Nerd Font",
  "window.menuBarVisibility": "compact",

  // File exlucsions
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.vscode": true,
    "**/*.gd.uid": true // Godot script thingy
  },

  // Languages, formatting
  "python.pythonPath": "C:\\Users\\Hannes\\AppData\\Local\\Programs\\Python\\Python39\\python.exe",
  "liveServer.settings.donotVerifyTags": true,
  "liveServer.settings.donotShowInfoMsg": true,
  "editor.accessibilitySupport": "off",
  "[python]": {
    "editor.formatOnType": true
  },
  "C_Cpp.default.compilerPath": "cl.exe",
  "[dart]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.rulers": [80],
    "editor.selectionHighlight": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "onlySnippets",
    "editor.wordBasedSuggestions": "off"
  },
  "[cpp]": {
    "editor.wordBasedSuggestions": "off",
    "editor.suggest.insertMode": "replace",
    "editor.semanticHighlighting.enabled": true
  },
  "javascript.updateImportsOnFileMove.enabled": "always",

  "[markdown]": {
    "files.trimTrailingWhitespace": false
  },
  "svelte.enable-ts-plugin": true,
  "supermaven.enable": {
    "*": true
  },
  "tailwindCSS.includeLanguages": {
    "\"svelte\"": "\"html\""
  },
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },

  // Misc
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "extensions.ignoreRecommendations": true,
  "workbench.colorTheme": "Min Dark",
  "godotTools.editorPath.godot4": "C:\\Users\\Hannes\\godot-v4.4.1\\Godot_v4.4.1-stable_win64.exe",
  "godotTools.lsp.serverPort": 6005
}
