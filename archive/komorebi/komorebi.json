{
  "$schema": "https://raw.githubusercontent.com/LGUG2Z/komorebi/v0.1.36/schema.json",
  "app_specific_configuration_path": "$Env:KOMOREBI_CONFIG_HOME/applications.json",
  "window_hiding_behaviour": "Cloak",
  "cross_monitor_move_behaviour": "Insert",
  "default_workspace_padding": 0,
  "default_container_padding": 0,
  "border": true,
  "border_width": 2,
  "border_offset": 0,
  "resize_delta": 200,
  "theme": {
    "palette": "Base16",
    "name": "Everforest"
  },
  "animation": {
    "enabled": true,
    "duration": 120,
    "fps": 144,
    "style": "EaseInOutExpo"
  },
  "transparency": true,
  "transparency_alpha": 210,
  "transparency_ignore_rules": [
    {
      "kind": "Exe",
      "id": "zen.exe",
      "matching_strategy": "Equals"
    }
  ],
  "monitors": [
    {
      "workspaces": [
        {
          "name": "I",
          "layout": "VerticalStack",
          "initial_workspace_rules": [
            {
              "kind": "Exe",
              "id": "zen.exe",
              "matching_strategy": "Equals"
            }
          ]
        },
        {
          "name": "II",
          "layout": "VerticalStack",
          "initial_workspace_rules": [
            {
              "kind": "Exe",
              "id": "Code.exe",
              "matching_strategy": "Equals"
            }
          ]
        },
        {
          "name": "III",
          "layout": "VerticalStack"
        }
      ]
    }
  ],
  "ignore_rules": [
    {
      "kind": "Exe",
      "id": "FL64.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "MiniMeters.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Title",
      "id": "- File Explorer",
      "matching_strategy": "Contains"
    },
    {
      "kind": "Exe",
      "id": "Spotify.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Title",
      "id": "- Discord",
      "matching_strategy": "Contains"
    },
    {
      "kind": "Title",
      "id": "Steam",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "yasb.exe",
      "matching_strategy": "Equals"
    },
    {
      "kind": "Exe",
      "id": "cs2.exe",
      "matching_strategy": "Equals"
    }
  ]
}
